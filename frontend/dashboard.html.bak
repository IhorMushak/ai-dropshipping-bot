<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Dropshipping Bot - Pro Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #0f0f0f; }
        .card { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); }
        .btn { transition: all 0.2s ease; cursor: pointer; }
        .btn:hover { transform: translateY(-1px); filter: brightness(1.05); }
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: #1a1a2e; }
        ::-webkit-scrollbar-thumb { background: #3b82f6; border-radius: 10px; }
        table { border-collapse: collapse; width: 100%; }
        th, td { padding: 12px 16px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.05); }
        th { color: #9ca3af; font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; }
        tr:hover { background: rgba(59,130,246,0.05); }
        .badge { padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
        .badge-green { background: rgba(34,197,94,0.2); color: #4ade80; }
        .badge-blue { background: rgba(59,130,246,0.2); color: #60a5fa; }
        .badge-yellow { background: rgba(234,179,8,0.2); color: #facc15; }
        .badge-purple { background: rgba(168,85,247,0.2); color: #a855f7; }
        .badge-gray { background: rgba(107,114,128,0.2); color: #9ca3af; }
        .product-card { background: #1a1a2e; border-radius: 16px; transition: all 0.2s; cursor: pointer; border: 1px solid rgba(255,255,255,0.05); }
        .product-card:hover { transform: translateY(-4px); border-color: #3b82f6; box-shadow: 0 10px 30px rgba(59,130,246,0.2); }
        .modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.9); display: flex; align-items: center; justify-content: center; z-index: 1000; }
        .modal-content { background: #1a1a2e; border-radius: 24px; max-width: 600px; width: 90%; max-height: 85vh; overflow-y: auto; border: 1px solid rgba(59,130,246,0.3); }
    </style>
</head>
<body class="text-white p-6">
    <div class="max-w-7xl mx-auto">
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">🤖 AI Dropshipping Bot</h1>
                <p class="text-gray-400 text-sm mt-1">Autonomous Dropshipping Platform</p>
            </div>
            <div class="flex gap-3">
                <a href="landing.html" class="btn bg-purple-600 hover:bg-purple-500 px-5 py-2 rounded-xl text-sm font-medium flex items-center gap-2">📄 Landing Pages</a>
                <button onclick="refreshAll()" class="btn bg-gray-800 hover:bg-gray-700 px-5 py-2 rounded-xl text-sm font-medium flex items-center gap-2">🔄 Refresh</button>
                <button onclick="showTrendsModal()" class="btn bg-green-600 hover:bg-green-500 px-5 py-2 rounded-xl text-sm font-medium flex items-center gap-2">📊 Trends</button>
                <button onclick="runPipeline()" class="btn bg-blue-600 hover:bg-blue-500 px-5 py-2 rounded-xl text-sm font-medium flex items-center gap-2">⚡ Run Pipeline</button>
            </div>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
            <div class="card p-5"><div class="text-gray-400 text-sm">Total Orders</div><div class="text-3xl font-bold mt-1" id="totalOrders">0</div></div>
            <div class="card p-5"><div class="text-gray-400 text-sm">Revenue</div><div class="text-3xl font-bold text-green-400 mt-1" id="revenue">$0</div></div>
            <div class="card p-5"><div class="text-gray-400 text-sm">Profit</div><div class="text-3xl font-bold text-purple-400 mt-1" id="profit">$0</div></div>
            <div class="card p-5"><div class="text-gray-400 text-sm">Active Products</div><div class="text-3xl font-bold text-orange-400 mt-1" id="activeProducts">0</div></div>
        </div>

        <!-- Charts -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 mb-8">
            <div class="card p-5"><h3 class="font-semibold mb-4">📈 Sales Trend (7d)</h3><canvas id="salesChart" height="180"></canvas></div>
            <div class="card p-5"><h3 class="font-semibold mb-4">🎯 Scores Distribution</h3><canvas id="scoresChart" height="180"></canvas></div>
        </div>

        <!-- Products Gallery View -->
        <div class="mb-6 flex justify-between items-center">
            <h2 class="text-xl font-semibold">📦 Products Gallery</h2>
            <div class="flex gap-3">
                <button onclick="toggleView()" class="btn bg-gray-800 hover:bg-gray-700 px-4 py-1.5 rounded-lg text-sm flex items-center gap-2" id="viewToggleBtn">🖼️ Grid View</button>
                <input type="text" id="searchInput" placeholder="Search products..." class="bg-gray-800 rounded-lg px-4 py-1.5 text-sm border border-gray-700 focus:outline-none focus:border-blue-500 w-64">
                <select id="statusFilter" class="bg-gray-800 rounded-lg px-4 py-1.5 text-sm border border-gray-700">
                    <option value="all">All Status</option>
                    <option value="discovered">Discovered</option>
                    <option value="published">Published</option>
                    <option value="active">Active</option>
                </select>
            </div>
        </div>

        <!-- Products Container -->
        <div id="productsContainer" class="mb-8"></div>

        <!-- Orders & Campaigns -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
            <div class="card"><div class="p-5 border-b border-white/5"><h2 class="text-xl font-semibold">🛒 Recent Orders</h2></div><div class="overflow-x-auto"><table class="w-full"><thead><tr><th>Order #</th><th>Amount</th><th>Status</th><th>Action</th></tr></thead><tbody id="ordersTable"></tbody></table></div></div>
            <div class="card"><div class="p-5 border-b border-white/5"><h2 class="text-xl font-semibold">🚀 Active Campaigns</h2></div><div class="overflow-x-auto"><table class="w-full"><thead><tr><th>Platform</th><th>Budget</th><th>Status</th><th>Product</th></tr></thead><tbody id="campaignsTable"></tbody></table></div></div>
        </div>
    </div>

    <!-- Product Detail Modal -->
    <div id="productModal" class="modal hidden" onclick="if(event.target===this) closeProductModal()">
        <div class="modal-content">
            <div class="p-5 border-b border-gray-700 flex justify-between items-center">
                <h2 class="text-xl font-semibold" id="modalProductName">Product Details</h2>
                <button onclick="closeProductModal()" class="text-gray-400 hover:text-white text-2xl">&times;</button>
            </div>
            <div class="p-5" id="modalProductContent"></div>
        </div>
    </div>

    <!-- Trends Modal -->
    <div id="trendsModal" class="modal hidden" onclick="if(event.target===this) closeTrendsModal()">
        <div class="modal-content">
            <div class="p-5 border-b border-gray-700 flex justify-between items-center">
                <h2 class="text-xl font-semibold">📊 Trending Products</h2>
                <button onclick="closeTrendsModal()" class="text-gray-400 hover:text-white text-2xl">&times;</button>
            </div>
            <div class="p-5">
                <div class="flex gap-3 mb-4">
                    <button onclick="scanTrends()" class="btn bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-lg text-sm">🔄 Scan Trends Now</button>
                    <select id="trendSourceFilter" class="bg-gray-800 rounded-lg px-3 py-2 text-sm border border-gray-700">
                        <option value="all">All Sources</option>
                        <option value="google">Google Trends</option>
                        <option value="tiktok">TikTok</option>
                    </select>
                </div>
                <div id="trendsList" class="max-h-96 overflow-y-auto"><div class="text-center text-gray-400 py-8">Loading trends...</div></div>
            </div>
        </div>
    </div>

    <div id="toast" class="fixed bottom-5 right-5 bg-gray-800 text-white px-5 py-3 rounded-xl shadow-xl hidden"></div>

    <script>
        const API = 'http://localhost:8000/api/v1';
        let salesChart, scoresChart, isGridView = true;
        let productsCache = [];

        function toast(msg, err=false){ let t=document.getElementById('toast'); t.textContent=msg; t.className=`fixed bottom-5 right-5 px-5 py-3 rounded-xl shadow-xl ${err?'bg-red-600':'bg-green-600'}`; t.classList.remove('hidden'); setTimeout(()=>t.classList.add('hidden'),3000); }

        async function api(endpoint, opts={}){ try{ let res=await fetch(`${API}${endpoint}`,{method:opts.method||'GET',headers:{'Content-Type':'application/json'}}); if(!res.ok)throw new Error(); return await res.json(); }catch(e){ return null; }}

        async function scoreProduct(id){ let r=await api(`/products/${id}/score`,{method:'POST'}); if(r) toast(`✅ Scored: ${r.final_score} - ${r.recommendation}`); refreshAll(); }
        async function publishProduct(id){ let r=await api(`/publish/${id}`,{method:'POST'}); if(r?.success) toast(`✅ Published: ${r.product_name}`); refreshAll(); }
        async function createAd(id){ let r=await api(`/ads/create/${id}?platform=meta`,{method:'POST'}); if(r?.success) toast(`🚀 Ad campaign created!`); refreshAll(); }
        async function processOrder(id){ let r=await api(`/orders/${id}/process`,{method:'POST'}); if(r?.success) toast(`📦 Order ${r.order_number} processed`); refreshAll(); }
        async function runPipeline(){ toast('🚀 Running pipeline...'); let r=await api('/trends/scan?geo=US',{method:'POST'}); if(r) toast(`📊 Scanned ${r.total_scanned} trends, created ${r.products_created} products`); refreshAll(); }
        async function scanTrends(){ toast('📊 Scanning trends...'); let r=await api('/trends/scan?geo=US',{method:'POST'}); if(r) toast(`Found ${r.total_scanned} trends, ${r.products_created} new products`); loadTrends(); refreshAll(); }

        function getProductImageUrl(p){ if(p.images && p.images[0]) return p.images[0]; return `https://placehold.co/400x300/1a1a2e/3b82f6?text=${encodeURIComponent(p.name.substring(0,20))}`; }

        function showProductDetail(product){
            let images = product.images || [];
            let imageHtml = images.length ? `<div class="image-gallery flex gap-2 overflow-x-auto">${images.map(img => `<img src="${img}" class="w-24 h-24 object-cover rounded cursor-pointer" onclick="window.open('${img}')">`).join('')}</div>` : `<div class="bg-gray-800 rounded-lg p-8 text-center text-gray-400">No images</div>`;
            let score = product.final_score || product.trend_score || 0;
            document.getElementById('modalProductName').innerHTML = product.name.substring(0,50);
            document.getElementById('modalProductContent').innerHTML = `<div class="space-y-4">${imageHtml}<div class="grid grid-cols-2 gap-3"><div class="bg-gray-800 p-3 rounded"><div class="text-gray-400 text-xs">Score</div><div class="text-xl font-bold text-green-400">${score}</div></div><div class="bg-gray-800 p-3 rounded"><div class="text-gray-400 text-xs">Price</div><div class="text-xl font-bold text-purple-400">$${(product.selling_price||0).toFixed(2)}</div></div></div><div class="flex gap-2">${product.status==='discovered'?`<button onclick="scoreProduct('${product.id}');closeProductModal()" class="btn bg-yellow-600 px-4 py-2 rounded-lg flex-1">Score</button>`:''}${product.status!=='published'?`<button onclick="publishProduct('${product.id}');closeProductModal()" class="btn bg-blue-600 px-4 py-2 rounded-lg flex-1">Publish</button>`:''}<button onclick="createAd('${product.id}');closeProductModal()" class="btn bg-purple-600 px-4 py-2 rounded-lg flex-1">Create Ad</button></div></div>`;
            document.getElementById('productModal').classList.remove('hidden');
        }
        function closeProductModal(){ document.getElementById('productModal').classList.add('hidden'); }

        async function loadTrends(){
            let trends=await api('/trends?limit=50');
            if(!trends?.items) return;
            let sourceFilter=document.getElementById('trendSourceFilter')?.value||'all';
            let filtered=trends.items.filter(t=>sourceFilter==='all'||t.source===sourceFilter);
            let html='<div class="space-y-2">';
            for(let t of filtered.slice(0,30)){
                let scoreClass=t.score>=80?'text-green-400':t.score>=60?'text-yellow-400':'text-gray-400';
                html+=`<div class="bg-gray-800 rounded-lg p-3 flex justify-between items-center hover:bg-gray-700"><div><span class="font-medium">${t.keyword}</span><div class="text-xs text-gray-400">${t.source}</div></div><div class="text-right"><div class="${scoreClass} font-bold">${t.score}</div><button onclick="createProductFromTrend('${t.keyword}')" class="text-xs bg-blue-600/30 hover:bg-blue-600/50 px-2 py-1 rounded mt-1">Create Product</button></div></div>`;
            }
            html+='</div>';
            document.getElementById('trendsList').innerHTML=html;
        }
        async function createProductFromTrend(k){ toast(`Creating product from trend: ${k}...`); await api('/trends/scan?geo=US',{method:'POST'}); refreshAll(); closeTrendsModal(); }
        function showTrendsModal(){ document.getElementById('trendsModal').classList.remove('hidden'); loadTrends(); }
        function closeTrendsModal(){ document.getElementById('trendsModal').classList.add('hidden'); }

        function toggleView(){ isGridView = !isGridView; document.getElementById('viewToggleBtn').innerHTML = isGridView ? '🖼️ Grid View' : '📋 Table View'; loadProducts(); }

        async function loadProducts(){
            let products=await api('/products/');
            if(!products) return;
            productsCache = products;
            let search=document.getElementById('searchInput')?.value.toLowerCase()||'', filter=document.getElementById('statusFilter')?.value||'all';
            let filtered=products.filter(p=>(!search||p.name.toLowerCase().includes(search))&&(filter==='all'||p.status===filter));
            let active=products.filter(p=>p.status==='published'||p.status==='active').length;
            document.getElementById('activeProducts').innerText=active;
            let container=document.getElementById('productsContainer');
            if(isGridView){
                let html='<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">';
                for(let p of filtered.slice(0,30)){
                    let score=p.final_score||p.trend_score||0;
                    let scoreColor=score>=80?'text-green-400':score>=60?'text-yellow-400':'text-gray-400';
                    let statusColor=p.status==='published'||p.status==='active'?'badge-green':'badge-blue';
                    let imageUrl = getProductImageUrl(p);
                    html+=`<div class="product-card p-4" onclick="showProductDetail(productsCache.find(prod=>prod.id==='${p.id}'))"><div class="relative"><img src="${imageUrl}" class="w-full h-48 object-cover rounded-lg mb-3" onerror="this.src='https://placehold.co/400x300/1a1a2e/3b82f6?text=No+Image'"><div class="absolute top-2 right-2"><span class="badge ${statusColor} text-xs">${p.status}</span></div></div><h3 class="font-semibold text-sm mb-1 line-clamp-2">${p.name.substring(0,60)}${p.name.length>60?'...':''}</h3><div class="flex justify-between items-center mt-2"><div><span class="text-green-400 font-bold text-lg">$${(p.selling_price||0).toFixed(2)}</span><span class="text-xs text-gray-400 ml-1">${p.margin_percent?p.margin_percent+'%':'0%'}</span></div><div class="${scoreColor} font-semibold text-sm">Score: ${score||'N/A'}</div></div><div class="flex gap-2 mt-3">${p.status==='discovered'?`<button onclick="event.stopPropagation();scoreProduct('${p.id}')" class="flex-1 bg-yellow-600/30 hover:bg-yellow-600/50 px-2 py-1.5 rounded-lg text-xs">Score</button>`:''}${p.status!=='published'&&p.status!=='active'?`<button onclick="event.stopPropagation();publishProduct('${p.id}')" class="flex-1 bg-blue-600/30 hover:bg-blue-600/50 px-2 py-1.5 rounded-lg text-xs">Publish</button>`:''}<button onclick="event.stopPropagation();createAd('${p.id}')" class="flex-1 bg-purple-600/30 hover:bg-purple-600/50 px-2 py-1.5 rounded-lg text-xs">Ad</button></div></div>`;
                }
                html+='</div>';
                container.innerHTML=html;
            } else {
                let html='<div class="card overflow-x-auto"><table class="w-full"><thead><tr><th>Image</th><th>Product</th><th>Score</th><th>Price</th><th>Margin</th><th>Status</th><th>Actions</th></tr></thead><tbody>';
                for(let p of filtered.slice(0,30)){
                    let score=p.final_score||p.trend_score||0, scoreClass=score>=80?'badge-green':score>=60?'badge-yellow':'badge-gray';
                    let statusClass=p.status==='published'||p.status==='active'?'badge-green':'badge-blue';
                    let imageUrl = getProductImageUrl(p);
                    html+=`<tr onclick="showProductDetail(productsCache.find(prod=>prod.id==='${p.id}'))" class="cursor-pointer hover:bg-gray-800"><td class="w-12"><img src="${imageUrl}" class="w-10 h-10 object-cover rounded" onerror="this.src='https://placehold.co/40x40/1a1a2e/3b82f6?text=?'"></td><td class="text-sm">${p.name.substring(0,45)}${p.name.length>45?'...':''}</td><td><span class="badge ${scoreClass}">${score||'N/A'}</span></td><td class="text-green-400">$${(p.selling_price||0).toFixed(2)}</td><td class="text-blue-400">${p.margin_percent?p.margin_percent+'%':'-'}</td><td><span class="badge ${statusClass}">${p.status}</span></td><td><div class="flex gap-1">${p.status==='discovered'?`<button onclick="event.stopPropagation();scoreProduct('${p.id}')" class="bg-yellow-600/30 hover:bg-yellow-600/50 px-2 py-1 rounded text-xs">Score</button>`:''}${p.status!=='published'&&p.status!=='active'?`<button onclick="event.stopPropagation();publishProduct('${p.id}')" class="bg-blue-600/30 hover:bg-blue-600/50 px-2 py-1 rounded text-xs">Publish</button>`:''}<button onclick="event.stopPropagation();createAd('${p.id}')" class="bg-purple-600/30 hover:bg-purple-600/50 px-2 py-1 rounded text-xs">Ad</button></div></td></tr>`;
                }
                html+='</tbody></table></div>';
                container.innerHTML=html;
            }
        }

        async function loadOrders(){
            let orders=await api('/orders/');
            if(!orders) return;
            let html='';
            for(let o of orders.slice(0,10)){
                let statusClass=o.status==='delivered'?'badge-green':o.status==='processing'?'badge-blue':'badge-yellow';
                html+=`<tr><td class="px-6 py-4 text-sm font-mono">${o.order_number}</td><td class="px-6 py-4 text-green-400">$${(o.total_amount||0).toFixed(2)}</td><td class="px-6 py-4"><span class="badge ${statusClass}">${o.status}</span></td><td class="px-6 py-4">${o.status==='pending'?`<button onclick="processOrder('${o.id}')" class="bg-gray-700 hover:bg-gray-600 px-2 py-1 rounded text-xs">Process</button>`:'-'}</td></tr>`;
            }
            document.getElementById('ordersTable').innerHTML=html||'<tr><td colspan="4" class="text-center py-8 text-gray-400">No orders</td></tr>';
        }

        async function loadCampaigns(){
            let data=await api('/ads/campaigns');
            if(!data?.campaigns) return;
            let html='';
            for(let c of data.campaigns.filter(c=>c.status==='active').slice(0,10)){
                html+=`<tr><td class="px-6 py-4">${c.platform}</td><td class="px-6 py-4 text-green-400">$${c.daily_budget}/day</td><td class="px-6 py-4"><span class="badge badge-green">${c.status}</span></td><td class="px-6 py-4 text-gray-400">${c.product_id?.substring(0,8)}...</td></tr>`;
            }
            document.getElementById('campaignsTable').innerHTML=html||'<tr><td colspan="4" class="text-center py-8 text-gray-400">No campaigns</td></tr>';
        }

        async function loadMetrics(){
            let m=await api('/dashboard/metrics');
            if(m){ document.getElementById('totalOrders').innerText=m.total_orders||0; document.getElementById('revenue').innerText=`$${(m.revenue||0).toFixed(2)}`; document.getElementById('profit').innerText=`$${(m.profit||0).toFixed(2)}`; }
        }

        async function loadCharts(){
            let orders=await api('/orders/')||[], products=await api('/products/')||[];
            if(salesChart) salesChart.destroy();
            let days=[...Array(7)].map((_,i)=>{let d=new Date(); d.setDate(d.getDate()-(6-i)); return d.toLocaleDateString('en-US',{month:'short',day:'numeric'});});
            let sales=days.map(day=> orders.filter(o=>new Date(o.order_placed_at).toLocaleDateString('en-US',{month:'short',day:'numeric'})===day).reduce((s,o)=>s+(o.total_amount||0),0));
            salesChart=new Chart(document.getElementById('salesChart'),{type:'line',data:{labels:days,datasets:[{label:'Revenue',data:sales,borderColor:'#3b82f6',backgroundColor:'rgba(59,130,246,0.1)',tension:0.4,fill:true}]},options:{responsive:true,maintainAspectRatio:true,plugins:{legend:{labels:{color:'#9ca3af'}}},scales:{y:{ticks:{color:'#9ca3af'},grid:{color:'#1f2937'}},x:{ticks:{color:'#9ca3af'},grid:{color:'#1f2937'}}}}});
            if(scoresChart) scoresChart.destroy();
            let ranges={'0-20':0,'21-40':0,'41-60':0,'61-80':0,'81-100':0};
            products.forEach(p=>{let s=p.final_score||p.trend_score||0; if(s>=81) ranges['81-100']++; else if(s>=61) ranges['61-80']++; else if(s>=41) ranges['41-60']++; else if(s>=21) ranges['21-40']++; else ranges['0-20']++;});
            scoresChart=new Chart(document.getElementById('scoresChart'),{type:'bar',data:{labels:Object.keys(ranges),datasets:[{label:'Products',data:Object.values(ranges),backgroundColor:'#8b5cf6',borderRadius:8}]},options:{responsive:true,maintainAspectRatio:true,plugins:{legend:{labels:{color:'#9ca3af'}}},scales:{y:{ticks:{color:'#9ca3af',stepSize:1},grid:{color:'#1f2937'}},x:{ticks:{color:'#9ca3af'},grid:{color:'#1f2937'}}}}});
        }

        async function refreshAll(){ await Promise.all([loadMetrics(),loadProducts(),loadOrders(),loadCampaigns(),loadCharts()]); toast('📊 Dashboard updated'); }
        
        document.getElementById('searchInput')?.addEventListener('input',()=>loadProducts());
        document.getElementById('statusFilter')?.addEventListener('change',()=>loadProducts());
        document.getElementById('trendSourceFilter')?.addEventListener('change',()=>loadTrends());
        
        refreshAll();
        setInterval(refreshAll, 30000);
    </script>
</body>
</html>

<!-- SEO Publisher Section -->
<div class="card mt-8">
    <div class="px-6 py-4 border-b border-white/5 flex justify-between items-center">
        <h2 class="text-xl font-semibold">📝 SEO Publisher (Medium + Pinterest)</h2>
        <button onclick="openSEOModal()" class="px-4 py-2 bg-green-600 rounded-lg hover:bg-green-500 text-sm">+ Generate SEO Content</button>
    </div>
    <div id="seoContent" class="p-4 hidden">
        <div class="bg-gray-800 rounded-lg p-4 mb-4">
            <h3 class="font-semibold mb-2">📄 Medium Article</h3>
            <pre id="mediumArticle" class="bg-gray-900 p-3 rounded text-sm overflow-x-auto whitespace-pre-wrap"></pre>
            <button onclick="copyToClipboard(document.getElementById('mediumArticle').innerText)" class="mt-2 bg-blue-600 px-3 py-1 rounded text-sm">Copy Article</button>
        </div>
        <div class="bg-gray-800 rounded-lg p-4">
            <h3 class="font-semibold mb-2">📌 Pinterest Pin</h3>
            <div id="pinContent" class="bg-gray-900 p-3 rounded text-sm"></div>
            <button onclick="copyToClipboard(document.getElementById('pinContent').innerText)" class="mt-2 bg-red-600 px-3 py-1 rounded text-sm">Copy Pin</button>
        </div>
    </div>
</div>

<!-- SEO Modal -->
<div id="seoModal" class="modal hidden" onclick="if(event.target===this) closeSEOModal()">
    <div class="modal-content p-6">
        <h3 class="text-xl font-semibold mb-4">Generate SEO Content</h3>
        <select id="seoProductSelect" class="w-full bg-gray-700 rounded-lg px-3 py-2 mb-4 border border-gray-600">
            <option value="">Select product...</option>
        </select>
        <button onclick="generateSEO()" class="w-full bg-purple-600 py-2 rounded-lg hover:bg-purple-500">Generate Article & Pin</button>
    </div>
</div>

<script>
async function loadSEOProducts() {
    let products = await api('/products/');
    if(!products) return;
    let select = document.getElementById('seoProductSelect');
    select.innerHTML = '<option value="">Select product...</option>' + 
        products.filter(p => p.status === 'published').map(p => `<option value="${p.id}">${p.name.substring(0,50)} (Score: ${p.final_score||p.trend_score||0})</option>`).join('');
}

$(cat /tmp/seo_fix.js)
    
    let result = await api(`/seo/article/${id}`);
    if(result) {
        document.getElementById('mediumArticle').innerText = result.article || 'No article generated';
        let pinHtml = `<div class="mb-2"><strong>Title:</strong> ${result.pin?.title || 'N/A'}</div>
                       <div class="mb-2"><strong>Description:</strong> ${result.pin?.description || 'N/A'}</div>
                       <div class="mb-2"><strong>Image URL:</strong> ${result.pin?.image_url || 'N/A'}</div>
                       <div><strong>Destination:</strong> ${result.pin?.destination_url || 'N/A'}</div>`;
        document.getElementById('pinContent').innerHTML = pinHtml;
        document.getElementById('seoContent').classList.remove('hidden');
        toast('✅ SEO content generated!');
        closeSEOModal();
    }
}

function openSEOModal() { loadSEOProducts(); document.getElementById('seoModal').classList.remove('hidden'); }
function closeSEOModal() { document.getElementById('seoModal').classList.add('hidden'); }

function copyToClipboard(text) {
    navigator.clipboard.writeText(text);
    toast('📋 Copied to clipboard!');
}
</script>
<script>
// Функції для SEO (додаємо якщо відсутні)
$(cat /tmp/seo_fix.js)
    
    let result = await api(`/seo/generate/${id}`);
    if(result) {
        document.getElementById('mediumArticle').innerHTML = result.medium_article?.content || 'No content';
        document.getElementById('pinTitle').innerHTML = result.pinterest_pin?.title || 'No title';
        document.getElementById('pinDesc').innerHTML = result.pinterest_pin?.description || 'No description';
        document.getElementById('seoContent').classList.remove('hidden');
    }
}
</script>
